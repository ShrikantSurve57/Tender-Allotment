<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Payment</title>

<style>
    body{
        font-family: Arial, sans-serif;
        background: #f2f4f7;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
    }

    .container{
        background: white;
        width: 380px;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 0 15px rgba(0,0,0,0.2);
        animation: fadeIn 0.4s ease;
    }

    h2{
        text-align: center;
        color: #2c3e50;
        margin-bottom: 25px;
    }

    label{
        font-size: 15px;
        font-weight: bold;
        color: #34495e;
    }

    input{
        width: 100%;
        padding: 10px;
        margin: 8px 0 18px 0;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 15px;
    }

    button{
        width: 100%;
        background: #007bff;
        color: white;
        padding: 12px;
        font-size: 16px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: 0.3s ease;
    }

    button:hover{
        background: #0056b3;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>

</head>
<body>

<div class="container">
    <h2>Make Payment</h2>

    <form action="PaymentSrv" method="post">

        <label>Vendor ID:</label>
        <input type="number" name="vendorId" required>

        <label>Tender ID:</label>
        <input type="number" name="tenderId" required>

        <label>Amount:</label>
        <input type="number" step="0.01" name="amount" required>

        <button type="submit">Make Payment</button>

    </form>
</div>

</body>
</html>
